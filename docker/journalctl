#!/bin/bash

LOG=/var/log/wg-quick.log
n=100

while [ $# -gt 0 ]; do
  case "$1" in
    -n) n=$2; shift 2 ;;
    -n*) n=${1#-n}; shift ;;
    --vacuum-time=*)
      if [ -f "$LOG" ]; then
        tmp=$(tail -n 500 "$LOG") && printf '%s\n' "$tmp" > "$LOG"
      fi
      echo "Vacuuming done."
      exit 0 ;;
    *) shift ;;
  esac
done

[ -f "$LOG" ] && tail -n "$n" "$LOG"
exit 0
